# Environment configuration for verdery-dev.
#
# Source: ADR-0007 (region), ADR-0011 (scripts instead of Terraform).
# Read by every script in infrastructure/gcloud/scripts/ — nothing here is
# hardcoded into a script, so a future staging.env or prod.env stands up an
# equivalent environment without editing script logic.

VERDERY_ENVIRONMENT="development"
VERDERY_PROJECT_ID="verdery-dev"
VERDERY_PROJECT_NAME="Verdery Dev"
VERDERY_BILLING_ACCOUNT_ID="011376-3DA0B7-CA8AC5"
VERDERY_REGION="us-central1"

VERDERY_NETWORK_NAME="verdery-dev-network"
VERDERY_SUBNET_NAME="verdery-dev-subnet"
VERDERY_SUBNET_RANGE="10.60.0.0/20"
VERDERY_PEERING_RANGE_NAME="verdery-dev-google-managed-services"
VERDERY_PEERING_PREFIX_LENGTH="16"

VERDERY_SQL_INSTANCE_NAME="verdery-dev-pg"
VERDERY_SQL_DATABASE_VERSION="POSTGRES_17"
VERDERY_SQL_TIER="db-f1-micro"
VERDERY_SQL_DATABASE_NAME="verdery"

VERDERY_ARTIFACT_REPOSITORY="verdery"

VERDERY_USER_MEDIA_BUCKET="verdery-dev-user-media"
VERDERY_RAW_CAPTURE_BUCKET="verdery-dev-raw-capture"
VERDERY_DERIVED_BUCKET="verdery-dev-derived"
VERDERY_EXPORTS_BUCKET="verdery-dev-exports"

VERDERY_DEPLOY_SERVICE_ACCOUNT_ID="verdery-dev-deployer"
VERDERY_RUNTIME_SERVICE_ACCOUNT_ID="verdery-dev-api-runtime"
# P6-ASYNC-01: the relay/worker deployment's own least-privilege identity,
# distinct from the API's runtime service account per architecture/media-
# storage-and-processing.md section 18 ("Separate read/write permissions by
# worker role") — see infrastructure/gcloud/scripts/10-media-processing-queue.sh
# (drafted, not yet run against verdery-dev).
VERDERY_WORKER_SERVICE_ACCOUNT_ID="verdery-dev-worker"

VERDERY_WORKLOAD_IDENTITY_POOL_ID="github-actions"
VERDERY_WORKLOAD_IDENTITY_PROVIDER_ID="github-actions-oidc"
VERDERY_GITHUB_REPOSITORY="t-boris/verdery"
VERDERY_GITHUB_ENVIRONMENT="development"

VERDERY_CLOUD_RUN_SERVICE_NAME="verdery-api-dev"
# P6-ASYNC-01: the always-on relay/worker Cloud Run service (min-instances=1 —
# see 10-media-processing-queue.sh's own comment for why this is a Service,
# not a Job) and its Cloud Tasks queue.
VERDERY_WORKERS_CLOUD_RUN_SERVICE_NAME="verdery-workers-dev"
VERDERY_MEDIA_PROCESSING_QUEUE_NAME="media-processing-dev"

# Cloud SQL access uses IAM database authentication, not a stored connection
# string — see infrastructure/gcloud/scripts/07-iam-database-bootstrap.sh —
# so there is deliberately no DATABASE_URL secret name here.

VERDERY_TRACING_ENABLED="true"
