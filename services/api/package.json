{
  "name": "@verdery/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Verdery backend: a Fastify modular monolith over PostgreSQL and PostGIS",
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "node --watch dist/main.js",
    "test": "vitest run",
    "migrate": "node-pg-migrate --migrations-dir migrations --envPath .env"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/under-pressure": "^9.1.0",
    "@verdery/api-contracts": "workspace:*",
    "@verdery/geometry-contracts": "workspace:*",
    "fastify": "^5.10.0",
    "kysely": "^0.29.4",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.4",
    "@types/node": "^24.10.4",
    "@types/pg": "^8.15.6",
    "@verdery/test-fixtures": "workspace:*",
    "node-pg-migrate": "^9.0.0",
    "testcontainers": "^12.0.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
