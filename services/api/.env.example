# Example environment for local development.
# Copy to `.env` and export before running the service or the migration CLI.
# Never commit a real connection string: `DATABASE_URL` is a secret.

VERDERY_ENVIRONMENT=development
SERVICE_VERSION=0.0.0-development

HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_BODY_LIMIT_BYTES=1048576
HTTP_ALLOWED_ORIGINS=http://localhost:3000

LOG_LEVEL=debug

# DATABASE_CONNECTION_MODE=url is for local development and matches what the
# Testcontainers suite uses. In Cloud Run, DATABASE_CONNECTION_MODE=cloudSqlIam
# is set instead, with DATABASE_INSTANCE_CONNECTION_NAME, DATABASE_IAM_USER,
# and DATABASE_NAME in place of DATABASE_URL — no password exists in that mode.
# See infrastructure/gcloud/scripts/07-iam-database-bootstrap.sh.
DATABASE_CONNECTION_MODE=url
DATABASE_URL=postgresql://verdery:verdery@localhost:5432/verdery
DATABASE_POOL_MAX_CONNECTIONS=10
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_STATEMENT_TIMEOUT_MS=10000

SHUTDOWN_GRACE_PERIOD_MS=15000

# Read by dist/telemetry-bootstrap.js, not by loadConfiguration() — tracing
# must initialize before the rest of the app's ESM graph loads, so it cannot
# depend on the same startup path. Off locally: there is no Cloud Trace
# project to export to, and `node --import` is only wired into `start`/`dev`.
TRACING_ENABLED=false
