# Origin of the Verdery API, without the /v1 version path and without a trailing slash.
# Not a secret: the browser has to know where to send its requests. Secrets never
# use NEXT_PUBLIC_ variables.
# Source: architecture/web-application-design.md, section "16. Security".
NEXT_PUBLIC_API_ORIGIN=http://localhost:8080

# Firebase web app config for the verdery-dev project. Not secrets — see
# environment.d.ts for why these use NEXT_PUBLIC_ deliberately.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyCpCHmqYIRCBHChWqEYsLSZwz7EKjnWBoU
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=verdery-dev.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=verdery-dev
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=verdery-dev.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=417008876420
NEXT_PUBLIC_FIREBASE_APP_ID=1:417008876420:web:f41b91b1e56ec5ab217bd1

# App Check reCAPTCHA Enterprise site key for the verdery-dev project. Not a
# secret — a reCAPTCHA site key is meant to ship in the client bundle, the
# same reasoning as the Firebase values above. Scoped to `localhost` only;
# see infrastructure/gcloud/scripts/08-app-check-recaptcha.sh.
NEXT_PUBLIC_RECAPTCHA_ENTERPRISE_SITE_KEY=6LfS618tAAAAAMMgqPSYDBKUEMdZ9xKQJGdv3Ehm

# NEXT_PUBLIC_USE_FIREBASE_EMULATOR is deliberately not listed here: it points
# the Firebase client SDK at the local Auth emulator instead of real Firebase,
# and is set only by apps/web/e2e/run-e2e.sh for the Playwright suite. Setting
# it for ordinary local development would silently disconnect this app from
# the real verdery-dev Firebase project above.
